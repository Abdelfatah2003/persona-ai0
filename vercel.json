{
  "framework": "flask",
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": "public",
  "installCommand": "pip install -r requirements.txt",
  "devCommand": "python app.py",
  "regions": ["fra1"],
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.11"
    }
  },
  "env": {
    "FLASK_ENV": "production",
    "FLASK_DEBUG": "0"
  }
}
